# Example environment variables for roadmap-english-ai
# Copy to .env.local or set these in Vercel dashboard

# DeepSeek API key (LLM)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Supadata API key (YouTube transcript import)
SUPADATA_API_KEY=sp_zzzzzzzzzzzzzzzzzzzz

# Soniox (speech-to-text) API key and optional workspace id
SONIOX_API_KEY=sonix_yyyyyyyyyyyyyyyyyy

GOOGLE_TTS_API_KEY=AIzaSy...your_key_here

# PostgreSQL (used by app + migrations)
DATABASE_URL=postgresql://user:password@host:5432/roadmap_english_ai

