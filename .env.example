# Copy to .env.local or set these in Vercel dashboard

# DeepSeek API key (LLM)
VITE_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Soniox (speech-to-text) API key and optional workspace id
VITE_SONIOX_API_KEY=sonix_yyyyyyyyyyyyyyyyyy

VITE_GOOGLE_TTS_API_KEY=AIzaSy...your_key_here

